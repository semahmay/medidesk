{
  "name": "medidesk-ai",
  "version": "1.0.0",
  "description": "AI-powered patient management tool for doctors",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run frontend\" \"npm run electron-dev\"",
    "frontend": "cd frontend && npm start",
    "electron-dev": "wait-on http://localhost:3000 && electron .",
    "build": "electron-builder",
    "install-deps": "npm install && cd frontend && npm install && cd ../backend && pip install -r requirements.txt"
  },
  "keywords": [
    "medical",
    "electron",
    "react",
    "ai",
    "patient-management"
  ],
  "author": "MediDesk AI",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-is-dev": "^2.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.medidesk.ai",
    "productName": "MediDesk AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/build/**/*",
      "backend/**/*",
      "data/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "asarUnpack": [
      "backend/**/*"
    ]
  },
  "dependencies": {
    "electron-store": "^11.0.2"
  }
}
