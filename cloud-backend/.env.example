# PostgreSQL (production - REQUIRED)
DATABASE_URL=postgresql://user:password@host:5432/medidesk

# JWT Secret — REQUIRED, app will crash on startup if not set
JWT_SECRET=generate_a_random_hex_string_here

# CORS — allowed origins for the cloud API
# Electron desktop: file://
# Production:      https://medidesk.app
# Dev:             http://localhost:3000,http://localhost
ALLOWED_ORIGINS=http://localhost:3000,http://localhost,file://

# MinIO / S3-compatible storage
MINIO_ROOT_USER=medidesk
MINIO_ROOT_PASSWORD=change_me
S3_BUCKET=medidesk-attachments

# Redis
REDIS_URL=redis://redis:6379/0

# Flask
FLASK_ENV=production
LOG_LEVEL=INFO

# Per-clinic storage quota in MB (default 500)
CLINIC_STORAGE_QUOTA_MB=500

# Error tracking (Sentry) — optional
# SENTRY_DSN=https://key@oXXX.ingest.sentry.io/XXX

# Deployment
GUNICORN_WORKERS=4
