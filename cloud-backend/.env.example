# SQLite (default, for local dev)
DATABASE_URL=sqlite:///./cloud.db

# PostgreSQL (uncomment when deploying to cloud)
# DATABASE_URL=postgresql://user:password@host:5432/medidesk_cloud

# JWT Secret — REQUIRED, app will crash on startup if not set.
# Generate a secure value with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_super_secure_random_string_here

# CORS — allowed origins for the cloud API
# Dev:        ALLOWED_ORIGINS=*
# Production: ALLOWED_ORIGINS=https://medidesk.app,https://app.medidesk.app
ALLOWED_ORIGINS=*
