# ── MediDesk AI — SaaS Production Environment ────────────────────────────────
# Copy to .env and fill in real values before deploying.

# ── Database ──────────────────────────────────────────────────────────────────
# SaaS: PostgreSQL
DATABASE_URL=postgresql://medidesk:CHANGE_ME@db:5432/medidesk

# Electron/dev: SQLite (default if DATABASE_URL not set)
# DATABASE_URL=sqlite:///./cloud.db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required for: rate limiting, WebSocket pub/sub, session cache
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_GENERATE_A_REAL_SECRET

# ── Object Storage ────────────────────────────────────────────────────────────
# SaaS mode: s3 (AWS S3 or MinIO)
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://minio:9000    # Remove for AWS S3
S3_BUCKET=medidesk-attachments
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_REGION=us-east-1

# Electron mode: local filesystem
# STORAGE_BACKEND=local
# LOCAL_STORAGE_PATH=./data/attachments

# ── PostgreSQL (used by docker-compose) ───────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME

# ── MinIO (used by docker-compose) ────────────────────────────────────────────
MINIO_ROOT_USER=medidesk
MINIO_ROOT_PASSWORD=CHANGE_ME_MIN_8_CHARS

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=production
