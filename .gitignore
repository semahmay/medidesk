# ── MediDesk AI — Git Ignore ─────────────────────────────────────────────────

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.production
*.env
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
ENV/
env/

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.npm
.eslintcache

# ── React Build ───────────────────────────────────────────────────────────────
medidesk-ai/frontend/build/
medidesk-ai/frontend/.env.local
medidesk-ai/frontend/.env.production.local

# ── Electron Build ────────────────────────────────────────────────────────────
medidesk-ai/dist/
medidesk-ai/out/
*.exe
*.dmg
*.AppImage

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-journal
cloud-backend/cloud.db*
medidesk-ai/data/medidesk.db*
medidesk-ai/data/users/*/medidesk.db*

# ── Docker ────────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Backups ───────────────────────────────────────────────────────────────────
medidesk-ai/_backup_*/
*.backup
*.bak

# ── Temporary Files ───────────────────────────────────────────────────────────
medidesk-ai/backend/temp/
medidesk-ai/frontend/src/temp/
*.tmp
.cache/

# ── User Data (Electron) ──────────────────────────────────────────────────────
medidesk-ai/data/users/
medidesk-ai/data/attachments/

# ── SSL Certificates (keep examples, ignore real certs) ──────────────────────
# Keep self-signed dev certs, ignore production certs
# cloud-backend/nginx/certs/*.pem (commented - we keep dev certs for now)

# ── Test Coverage ─────────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/

# ── OS ────────────────────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
